# 根据 reborn_core.config.Settings 自动生成。
# 真实凭证只能保存在 .env 中。

# 应用名称
APP_NAME=Project Reborn

# 应用版本
APP_VERSION=0.1.0

# 应用环境
APP_ENV=dev

# 日志目录
LOG_DIR=logs

# 日志级别
LOG_LEVEL=DEBUG

# 日志格式：auto 根据环境选择，pretty 为开发可读格式，json 为结构化日志。
LOG_FORMAT=auto

# 本地模型目录
MODELS_DIR=data/local_models

# HuggingFace 镜像地址
HF_MIRROR=https://hf-mirror.com

# SQLite 数据库路径
DB_PATH=data/sqlite/reborn.db

# 检索索引根目录
VECTOR_DB_PATH=data/retrieval

# 加密备份目录
BACKUP_DIR=data/backups

# RAG 记忆盲区记录文件路径
MEMORY_GAPS_PATH=data/memory_gaps.json

# Project Reborn 家庭资料 TOML 文件路径
PROJECT_PROFILE_PATH=data/project_profile.toml

# 后台任务工作线程数
TASK_WORKER_THREADS=2

# 保留的可用检索索引代次数量
RETRIEVAL_GENERATION_RETENTION=3

# 用于加密备份归档的 Fernet 密钥
BACKUP_ENCRYPTION_KEY=

# 是否拒绝创建未加密的明文备份
BACKUP_REQUIRE_ENCRYPTION=true

# 访问策略适配器；当前单用户默认值为 local_owner
ACCESS_POLICY_BACKEND=local_owner

# 数字遗产激活规则
LEGACY_ACTIVATION_MODE=owner_only

# 数字遗产激活凭证文件路径
LEGACY_ACTIVATION_FILE=data/governance/legacy_activation.json

# macOS 的 Obsidian 仓库路径
OBSIDIAN_VAULT_PATH_MAC=

# Windows 的 Obsidian 仓库路径
OBSIDIAN_VAULT_PATH_WIN=

# macOS 的音频资料路径
AUDIO_DATA_PATH_MAC=

# Windows 的音频资料路径
AUDIO_DATA_PATH_WIN=

# 大语言模型 API 基础地址
LLM_BASE_URL=https://api.deepseek.com

# 大语言模型 API 密钥
LLM_API_KEY=

# 大语言模型名称
LLM_MODEL_NAME=deepseek-chat

# STT 入口；设为 local 使用本地 FunASR，或填写 OpenAI-compatible base URL，例如 https://api.openai.com/v1 切换云端转写。
STT_ENDPOINT=local

# 语音转文字 API 密钥
STT_API_KEY=

# 语音转文字模型名称；本地模式为 FunASR 主模型名，云端模式为转写模型名
STT_MODEL_NAME=paraformer-zh

# 本地 STT 引擎；当前实现 funasr，whisper 为预留配置
STT_LOCAL_ENGINE=funasr

# FunASR VAD 模型名称；留空则禁用 VAD
FUNASR_VAD_MODEL_NAME=fsmn-vad

# FunASR 标点模型名称；留空则禁用标点恢复
FUNASR_PUNC_MODEL_NAME=ct-punc

# ModelScope/FunASR 模型缓存目录
MODELSCOPE_CACHE_DIR=data/local_models

# 价值观和身份核所在的 Obsidian 目录名
CORE_VALUES_FOLDER=02_Values

# 人生故事记忆所在的 Obsidian 目录名
STORIES_FOLDER=03_Stories

# AI 派生价值观反思所在的子目录名
AI_REFLECTIONS_FOLDER=00_AI_Reflections

# 不可变原始资料归档目录名
SOURCE_ARTIFACTS_FOLDER=01_Source_Artifacts

# 需要摄入检索索引的 Obsidian 目录
REBORN_TARGET_FOLDERS=["02_Values", "03_Stories"]
